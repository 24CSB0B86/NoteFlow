# ─────────────────────────────────────────────────────────────────────────────
# NoteFlow Client — Environment Variables
# Copy this file to .env and fill in your values.
# All VITE_ variables are embedded at build time (visible in browser bundles).
# NEVER put secrets here!
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# Development:
VITE_API_URL=http://localhost:3001
# Production (Render):
# VITE_API_URL=https://noteflow-api.onrender.com

# ── Supabase (public / anon key — safe to expose) ────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
