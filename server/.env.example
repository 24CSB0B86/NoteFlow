# ─────────────────────────────────────────────────────────────────────────────
# NoteFlow Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon DB — free tier) ────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Supabase (Storage & Auth) ─────────────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS — set to your Vercel frontend URL in production ─────────────────────
CLIENT_URL=http://localhost:5173

# ── JWT Secret (min 32 chars — use a random string) ──────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-random-jwt-key-min-32-chars

# ── AI / Chatbot ──────────────────────────────────────────────────────────────
# Option A: OpenAI (https://platform.openai.com/api-keys)
# Leave blank to use the built-in rule-based FAQ fallback (works without any key!)
OPENAI_API_KEY=sk-proj-...your-openai-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Option A: Gmail App Password (recommended for dev)
# Setup: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com

# Option B: Generic SMTP (Outlook, SendGrid, Mailgun, etc.)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASS=your-api-key
# EMAIL_FROM=noreply@yourdomain.com

# ── Redis (Optional — caching, leave blank to skip) ──────────────────────────
# Free options: https://upstash.com or https://redis.com/try-free/
REDIS_URL=redis://default:password@your-redis-host:6379

# ── Monitoring (Optional) ─────────────────────────────────────────────────────
# Sentry error tracking: https://sentry.io (free tier)
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ── Testing ───────────────────────────────────────────────────────────────────
# If set, tests will use this DB instead of DATABASE_URL (to protect prod data)
# TEST_DATABASE_URL=postgresql://test:test@localhost/noteflow_test
